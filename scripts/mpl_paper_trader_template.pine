//@version=6
strategy("MPL Trendline Break Strategy", overlay=true,
   initial_capital=10000, default_qty_type=strategy.fixed, default_qty_value=1,
   currency=currency.USD)

// --- How to use ----------------------------------------------------------
// 1. On the 4H chart zoomed to 3 months, identify a valid trendline:
//    3+ touches, 6+ candles between touches, 3+ weeks span, slope < 45 deg.
// 2. Note the TWO anchor points (A = earlier/left, B = later/right).
//    Enter their dates and prices in the Inputs below (click the gear icon).
// 3. Do the same for the Safety Line (the opposing trendline for the stop).
// 4. The script draws both lines and monitors for a candle close past Action.

// --- Action Line (the trendline to trade) ---------------------------------
al_d1 = input.time(timestamp("2025-01-01"), "Action Line - Date A")
al_p1 = input.float(0.0, "Action Line - Price A")
al_d2 = input.time(timestamp("2025-02-01"), "Action Line - Date B")
al_p2 = input.float(0.0, "Action Line - Price B")

// --- Safety Line (opposing trendline for stop loss) -----------------------
sl_d1 = input.time(timestamp("2025-01-01"), "Safety Line - Date A")
sl_p1 = input.float(0.0, "Safety Line - Price A")
sl_d2 = input.time(timestamp("2025-02-01"), "Safety Line - Date B")
sl_p2 = input.float(0.0, "Safety Line - Price B")

// --- Risk / Reward --------------------------------------------------------
tp_r = input.float(2.0, "Take Profit (R multiple)", step=0.5)

// --- Find bar indices for the input dates ---------------------------------
// Match within a 24h window for timezone tolerance.
day = 86400000
al_b1 = ta.valuewhen(time >= al_d1 and time < al_d1 + day, bar_index, 0)
al_b2 = ta.valuewhen(time >= al_d2 and time < al_d2 + day, bar_index, 0)
sl_b1 = ta.valuewhen(time >= sl_d1 and time < sl_d1 + day, bar_index, 0)
sl_b2 = ta.valuewhen(time >= sl_d2 and time < sl_d2 + day, bar_index, 0)

// --- Draw lines -----------------------------------------------------------
var line actionLine = line.new(na, na, na, na, extend=extend.right,
     color=color.blue, width=2)
var line safetyLine = line.new(na, na, na, na, extend=extend.right,
     color=color.red, width=2, style=line.style_dashed)

a_ok = not na(al_b1) and not na(al_b2)
s_ok = not na(sl_b1) and not na(sl_b2)

if a_ok
    line.set_xy1(actionLine, al_b1, al_p1)
    line.set_xy2(actionLine, al_b2, al_p2)
if s_ok
    line.set_xy1(safetyLine, sl_b1, sl_p1)
    line.set_xy2(safetyLine, sl_b2, sl_p2)

// --- Line value at a bar --------------------------------------------------
f_line(y1, x1, y2, x2, x) =>
    if na(x1) or na(x2) or x2 == x1
        na
    else
        y1 + ((y2 - y1) / (x2 - x1)) * (x - x1)

// --- Break detection ------------------------------------------------------
broken = false
is_bull = false
is_bear = false

if a_ok
    ap = f_line(al_p1, al_b1, al_p2, al_b2, bar_index)
    pp = f_line(al_p1, al_b1, al_p2, al_b2, bar_index[1])
    if not na(ap) and bar_index >= al_b2
        was_above = high[1] > pp
        was_below = low[1] < pp
        is_bull := was_below and close > ap
        is_bear := was_above and close < ap
        broken := is_bull or is_bear

// --- Entry ----------------------------------------------------------------
var int  attempt = 0
var float entryP = na
var float stopP  = na
var float tpP    = na
var int   dir    = 0

if broken and attempt == 0
    entryP := close
    dir := is_bull ? 1 : -1
    if s_ok
        stopP := f_line(sl_p1, sl_b1, sl_p2, sl_b2, bar_index + 4)
    else
        stopP := dir == 1 ? low - (high - low) * 2 : high + (high - low) * 2
    risk = math.abs(entryP - stopP)
    tpP := if dir == 1
        entryP + risk * tp_r
    else
        entryP - risk * tp_r
    label.new(bar_index, dir == 1 ? low : high,
         "BREAK\nE:" + str.tostring(entryP) + "\nS:" + str.tostring(stopP) + "\nT:" + str.tostring(tpP),
         style = dir == 1 ? label.style_label_up : label.style_label_down,
         color = dir == 1 ? color.green : color.red,
         textcolor = color.white, size = size.small)
    if dir == 1
        strategy.entry("L", strategy.long, alert_message="buy")
        strategy.exit("XL", "L", stop=stopP, limit=tpP, alert_message="exit_long")
    else
        strategy.entry("S", strategy.short, alert_message="sell")
        strategy.exit("XS", "S", stop=stopP, limit=tpP, alert_message="exit_short")
    attempt := 1

if strategy.position_size == 0 and attempt == 1
    attempt := 0
    entryP := na
    stopP := na
    tpP := na
    dir := 0

alertcondition(broken, "Trendline Break", "Price broke the Action Line")
