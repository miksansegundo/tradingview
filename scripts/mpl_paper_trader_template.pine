//@version=6
strategy("MPL Trendline Break Strategy", overlay=true,
   initial_capital=10000, default_qty_type=strategy.fixed, default_qty_value=1,
   currency=currency.USD)

// --- Parameters ---------------------------------------------------------
LOOKBACK   = input.int(540, "Lookback (bars)", minval=100)
PIVOT_LEN  = input.int(5,  "Pivot sensitivity", minval=1)
TOUCH_TOL  = input.float(0.003, "Touch tolerance %", step=0.001)
MIN_TAPS   = input.int(3,   "Min touches", minval=2)
MIN_CANDLE_GAP = input.int(6, "Min candles between taps", minval=1)
MIN_TIME_GAP   = input.int(14, "Min days between taps", minval=1)
SLOPE_DEG  = input.float(45.0, "Max slope (degrees)", minval=5, maxval=80)
TP_R_MULT  = input.float(2.0, "Take Profit (R multiple)", step=0.5)

// --- Pre-computed range for angle ---------------------------------------
chart_high = ta.highest(high, LOOKBACK)
chart_low  = ta.lowest(low, LOOKBACK)
prange = chart_high - chart_low
brange = LOOKBACK

// --- Trendline detection (runs ONCE, cached in var) --------------------
// Collect pivots once at the last bar and find the best trendline.
var float act_y1 = na
var int   act_x1 = na
var float act_y2 = na
var int   act_x2 = na
var float saf_y1 = na
var int   saf_x1 = na
var float saf_y2 = na
var int   saf_x2 = na
var bool  detected = false

if bar_index == last_bar_index - 1 and not detected
    // Collect pivot highs
    ph_series = ta.pivothigh(high, PIVOT_LEN, PIVOT_LEN)
    pl_series = ta.pivotlow(low, PIVOT_LEN, PIVOT_LEN)
    pivot_hp = array.new<float>()
    pivot_hb = array.new<int>()
    pivot_ht = array.new<int>()
    pivot_lp = array.new<float>()
    pivot_lb = array.new<int>()
    pivot_lt = array.new<int>()
    for i = PIVOT_LEN to LOOKBACK
        ph = ph_series[i]
        if not na(ph)
            array.push(pivot_hp, ph)
            array.push(pivot_hb, bar_index[i])
            array.push(pivot_ht, time[i])
        pl = pl_series[i]
        if not na(pl)
            array.push(pivot_lp, pl)
            array.push(pivot_lb, bar_index[i])
            array.push(pivot_lt, time[i])

    // Helper: find best line from a pivot set
    f_find(prices, bars, times) =>
        n = array.size(prices)
        best_n = 0
        by1 = float(na); bx1 = int(na); by2 = float(na); bx2 = int(na)
        g = MIN_TIME_GAP * 86400000
        for i = 0 to n - 2
            y1 = array.get(prices, i)
            x1 = array.get(bars, i)
            for j = i + 1 to n - 1
                y2 = array.get(prices, j)
                x2 = array.get(bars, j)
                rise = y2 - y1
                run = x2 - x1
                angle = math.abs(math.atan((rise / prange) / (run / brange)) * 180.0 / math.pi)
                if angle > SLOPE_DEG
                    continue
                span = x2 - x1
                if span < 126
                    continue
                cnt = 0
                lt_bar = -999
                lt_tim = 0
                for k = 0 to n - 1
                    px = array.get(bars, k)
                    py = array.get(prices, k)
                    pt = array.get(times, k)
                    if px < x1 or px > x2
                        continue
                    m = (y2 - y1) / (x2 - x1)
                    lp = y1 + m * (px - x1)
                    if math.abs(py - lp) / lp <= TOUCH_TOL
                        candle_ok = px - lt_bar >= MIN_CANDLE_GAP
                        time_ok = lt_tim == 0 or (pt - lt_tim) >= g
                        if candle_ok or time_ok
                            cnt += 1
                            lt_bar := px
                            lt_tim := pt
                if cnt >= best_n
                    best_n := cnt
                    by1 := y1; bx1 := x1; by2 := y2; bx2 := x2
        [best_n >= MIN_TAPS, by1, bx1, by2, bx2, best_n]

    [r_ok, r_y1, r_x1, r_y2, r_x2, r_n] = f_find(pivot_hp, pivot_hb, pivot_ht)
    [s_ok, s_y1, s_x1, s_y2, s_x2, s_n] = f_find(pivot_lp, pivot_lb, pivot_lt)

    if r_ok and s_ok
        if r_n >= s_n
            act_y1 := r_y1; act_x1 := r_x1; act_y2 := r_y2; act_x2 := r_x2
            saf_y1 := s_y1; saf_x1 := s_x1; saf_y2 := s_y2; saf_x2 := s_x2
            detected := true
        else
            act_y1 := s_y1; act_x1 := s_x1; act_y2 := s_y2; act_x2 := s_x2
            saf_y1 := r_y1; saf_x1 := r_x1; saf_y2 := r_y2; saf_x2 := r_x2
            detected := true
    else
        if r_ok
            act_y1 := r_y1; act_x1 := r_x1; act_y2 := r_y2; act_x2 := r_x2
            detected := true
        if s_ok
            act_y1 := s_y1; act_x1 := s_x1; act_y2 := s_y2; act_x2 := s_x2
            detected := true

// --- Draw lines (every bar to keep them extending) -----------------------
var line actionLine = line.new(na, na, na, na, extend=extend.right, color=color.blue, width=2)
var line safetyLine = line.new(na, na, na, na, extend=extend.right, color=color.red, width=2, style=line.style_dashed)

if detected
    line.set_xy1(actionLine, act_x1, act_y1)
    line.set_xy2(actionLine, act_x2, act_y2)
    if not na(saf_y1)
        line.set_xy1(safetyLine, saf_x1, saf_y1)
        line.set_xy2(safetyLine, saf_x2, saf_y2)

// --- Line value ----------------------------------------------------------
f_price(y1, x1, y2, x2, x) =>
    if na(x1) or na(x2) or x2 == x1
        na
    else
        y1 + ((y2 - y1) / (x2 - x1)) * (x - x1)

// --- Break detection -----------------------------------------------------
action_broken = false
break_is_bull = false

if detected
    ap = f_price(act_y1, act_x1, act_y2, act_x2, bar_index)
    pp = f_price(act_y1, act_x1, act_y2, act_x2, bar_index[1])
    if not na(ap) and bar_index >= act_x2
        was_above = high[1] > pp
        was_below = low[1] < pp
        break_is_bull := was_below and close > ap
        break_is_bear := was_above and close < ap
        action_broken := break_is_bull or break_is_bear

// --- Entry ---------------------------------------------------------------
var int  attempt = 0
var float entryP = na
var float stopP = na
var float tpP = na
var int  direction = 0

if action_broken and attempt == 0
    entryP := close
    direction := break_is_bull ? 1 : -1
    if not na(saf_y1)
        stopP := f_price(saf_y1, saf_x1, saf_y2, saf_x2, bar_index + 4)
    else
        stopP := direction == 1 ? low - (high - low) * 2 : high + (high - low) * 2
    risk = math.abs(entryP - stopP)
    tpP := if direction == 1
        entryP + risk * TP_R_MULT
    else
        entryP - risk * TP_R_MULT
    label.new(bar_index, direction == 1 ? low : high,
         "BREAK\nE:" + str.tostring(entryP) + "\nS:" + str.tostring(stopP) + "\nT:" + str.tostring(tpP),
         style = direction == 1 ? label.style_label_up : label.style_label_down,
         color = direction == 1 ? color.green : color.red,
         textcolor = color.white, size = size.small)
    if direction == 1
        strategy.entry("L", strategy.long, alert_message="buy")
        strategy.exit("XL", "L", stop=stopP, limit=tpP, alert_message="exit_long")
    else
        strategy.entry("S", strategy.short, alert_message="sell")
        strategy.exit("XS", "S", stop=stopP, limit=tpP, alert_message="exit_short")
    attempt := 1

if strategy.position_size == 0 and attempt == 1
    attempt := 0; entryP := na; stopP := na; tpP := na; direction := 0

alertcondition(action_broken, "Trendline Break", "Price broke the auto-detected trendline")
