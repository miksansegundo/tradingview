//@version=6
strategy("MPL Paper Trader Template", overlay=true,
   initial_capital=10000, default_qty_type=strategy.fixed, default_qty_value=1,
   currency=currency.USD)

// --- Strategy Parameters ------------------------------------------------
// Phase 2: replace these with your actual strategy inputs
buy_threshold  = input.float(0.0, "Buy Signal Threshold")
sell_threshold = input.float(0.0, "Sell Signal Threshold")

// --- Signal Generation --------------------------------------------------
// Phase 2: implement your strategy logic here.
// For now, this template generates no trades -- it's a skeleton to show
// the alert message format.

// Example placeholder -- replace with real strategy conditions:
// buy_condition  = ta.crossover(INDICATOR, buy_threshold)
// sell_condition = ta.crossunder(INDICATOR, sell_threshold)

// --- Alerts -------------------------------------------------------------
// When you add strategy.entry() / strategy.close() calls, create an Alert
// in TradingView for this strategy. In the alert creation dialog:
//   1. Condition: your strategy
//   2. Expiry: never (or as desired)
//   3. Webhook URL: https://your-ngrok-domain.ngrok-free.app/webhook/tradingview
//   4. Message: paste the JSON template below

// Expected webhook JSON format -- paste this into the alert message field:
//
// {
//   "ticker":   "{{ticker}}",
//   "action":   "{{strategy.order.alert_message}}",
//   "price":    {{strategy.order.price}},
//   "qty":      1,
//   "signal_id": "sig_{{timenow}}",
//   "strategy": "MPL Paper Trader Template"
// }
//
// Action values expected by the webhook server:
//   "buy"         -- open long (if flat) or error (if already long)
//   "sell"        -- open short (if flat) or error (if already short)
//   "exit_long"   -- close long position
//   "exit_short"  -- close short position
//   "close_all"   -- close current position regardless of direction

// When you execute a trade, pass the action via alert_message:
// strategy.entry("Long", strategy.long, alert_message="buy")
// strategy.close("Long", alert_message="exit_long")
