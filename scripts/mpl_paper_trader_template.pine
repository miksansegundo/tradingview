//@version=6
strategy("MPL Trendline Break Strategy", overlay=true,
   initial_capital=10000, default_qty_type=strategy.fixed, default_qty_value=1,
   currency=currency.USD)

// --- How to use ----------------------------------------------------------
// 1. Draw TWO trendlines on the chart using the Line tool (Alt+L):
//    - Action Line (blue): the trendline to trade -- 3+ touches, <45 deg
//    - Safety Line (red dashed): the opposing trendline that defines the stop
// 2. Open the script Settings (gear icon) and select each line from the dropdown.
// 3. The script monitors for a candle close past the Action Line.

// --- Inputs: pick the lines you drew on the chart -------------------------
actionLine = input.line(defval=na, title="Action Line (draw on chart)")
safetyLine = input.line(defval=na, title="Safety Line (draw on chart)")
tp_r = input.float(2.0, "Take Profit (R multiple)", step=0.5)

// --- Extend both lines to the right ---------------------------------------
if not na(actionLine)
    line.set_extend(actionLine, extend.right)
    line.set_style(actionLine, line.style_solid)
    line.set_width(actionLine, 2)
    line.set_color(actionLine, color.blue)
if not na(safetyLine)
    line.set_extend(safetyLine, extend.right)
    line.set_style(safetyLine, line.style_dashed)
    line.set_width(safetyLine, 2)
    line.set_color(safetyLine, color.red)

// --- Break detection ------------------------------------------------------
broken = false
is_bull = false
is_bear = false

a_ok = not na(actionLine)
s_ok = not na(safetyLine)

if a_ok
    ap = line.get_price(actionLine, bar_index)
    pp = line.get_price(actionLine, bar_index[1])
    ax2 = line.get_x2(actionLine)
    if not na(ap) and bar_index >= ax2
        was_above = high[1] > pp
        was_below = low[1] < pp
        is_bull := was_below and close > ap
        is_bear := was_above and close < ap
        broken := is_bull or is_bear

// --- Entry ----------------------------------------------------------------
var int  attempt = 0
var float entryP = na
var float stopP  = na
var float tpP    = na
var int   dir    = 0

if broken and attempt == 0
    entryP := close
    dir := is_bull ? 1 : -1
    if s_ok
        stopP := line.get_price(safetyLine, bar_index + 4)
    else
        stopP := dir == 1 ? low - (high - low) * 2 : high + (high - low) * 2
    risk = math.abs(entryP - stopP)
    tpP := if dir == 1
        entryP + risk * tp_r
    else
        entryP - risk * tp_r
    label.new(bar_index, dir == 1 ? low : high,
         "BREAK\nE:" + str.tostring(entryP) + "\nS:" + str.tostring(stopP) + "\nT:" + str.tostring(tpP),
         style = dir == 1 ? label.style_label_up : label.style_label_down,
         color = dir == 1 ? color.green : color.red,
         textcolor = color.white, size = size.small)
    if dir == 1
        strategy.entry("L", strategy.long, alert_message="buy")
        strategy.exit("XL", "L", stop=stopP, limit=tpP, alert_message="exit_long")
    else
        strategy.entry("S", strategy.short, alert_message="sell")
        strategy.exit("XS", "S", stop=stopP, limit=tpP, alert_message="exit_short")
    attempt := 1

if strategy.position_size == 0 and attempt == 1
    attempt := 0
    entryP := na
    stopP := na
    tpP := na
    dir := 0

alertcondition(broken, "Trendline Break", "Price broke the Action Line")
